{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchPackagePatterns": [
        "^@types/"
      ],
      "groupName": "TypeScript type definitions",
      "automerge": true
    },
    {
      "matchDepTypes": [
        "dependencies"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "prPriority": 5,
      "automerge": false
    },
    {
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "prPriority": -1
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^tool-versions\\.txt$"
      ],
      "matchStrings": [
        "node=(?<currentValue>[\\d\\.]+)\\n"
      ],
      "depNameTemplate": "nodejs/node",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^tool-versions\\.txt$"
      ],
      "matchStrings": [
        "terraform=(?<currentValue>[\\d\\.]+)\\n"
      ],
      "depNameTemplate": "hashicorp/terraform",
      "datasourceTemplate": "github-releases"
    }
  ]
}